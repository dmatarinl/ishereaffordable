{
  "version": "2026-06-spain-single-adult-v1",
  "profile": "One adult in Spain, one month of home groceries, no restaurant or delivery meals",
  "period": "month",
  "currency": "EUR",
  "aggregation_method": "median_valid_supermarket_basket",
  "pricing_policy": {
    "city_variation": "The basket stays identical for every city. Supermarket adapters price the same canonical items against products available for a representative city postcode.",
    "matching": "Match each canonical item to the cheapest qualifying standard product per supermarket and postcode, using normalized unit prices where possible. Prefer standard own-label products over premium, organic, bulk-only, or promotional-only products.",
    "substitutions": "Use substitutions only when a direct match is unavailable and the substitute is listed on the canonical item. Track substitution count separately from direct matches.",
    "unavailable_products": "A supermarket basket is valid only when required-item coverage meets the confidence threshold. Missing optional items lower transparency but should not invalidate the basket.",
    "city_total": "Compute a basket total per valid supermarket source, then use the median valid supermarket basket total for the city."
  },
  "source_basis": [
    {
      "name": "MAPA Panel de Consumo Alimentario",
      "url": "https://www.mapa.gob.es/es/alimentacion/temas/consumo-tendencias/panel-de-consumo-alimentario/",
      "use": "Grounds the basket in Spanish household food-consumption categories and trends."
    },
    {
      "name": "INE Encuesta de Presupuestos Familiares",
      "url": "https://www.ine.es/dyngs/INEbase/es/operacion.htm?c=Estadistica_C&cid=1254736176806&idp=1254735976608&menu=ultiDatos",
      "use": "Sanity-checks the resulting monthly food and grocery amount against observed household spending."
    },
    {
      "name": "AESAN Recomendaciones dieteticas y de actividad fisica",
      "url": "https://www.aesan.gob.es/AECOSAN/web/nutricion/subseccion/recomendaciones_dieteticas.htm",
      "use": "Keeps the basket aligned with Spanish healthy and sustainable diet guidance."
    }
  ],
  "confidence_thresholds": {
    "high": {
      "minimum_product_coverage": 0.9,
      "minimum_valid_sources": 2,
      "maximum_substitution_ratio": 0.25
    },
    "medium": {
      "minimum_product_coverage": 0.75,
      "minimum_valid_sources": 1,
      "maximum_substitution_ratio": 0.4
    },
    "low": {
      "minimum_product_coverage": 0.5,
      "minimum_valid_sources": 1,
      "maximum_substitution_ratio": 0.6
    }
  },
